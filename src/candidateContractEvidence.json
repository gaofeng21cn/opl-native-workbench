    "codex_app_server_thread_turn": true,
    "codex_command": "codex app-server --stdio",
    "codex_protocol": "JSON-RPC newline transport with initialize, model/list, paginated thread/list, thread/read, thread/resume, thread/fork, thread/archive, thread/unarchive, turn/start, turn/steer, thread/status/changed, client-executed dynamicTools item/tool/call, item/agentMessage/delta, and turn/completed",
