    "full_drilldown": "opl runtime app-operator-drilldown --detail full --json",
    "action": "opl app action execute --action <action_id> [--payload json] [--dry-run] --json"
  },
  "functional_mvp": {
    "codex_app_server_thread_turn": true,
    "codex_command": "codex app-server --stdio",
    "codex_protocol": "JSON-RPC newline transport with initialize, thread/start, turn/start, item/agentMessage/delta, turn/completed, thread/resume",
    "opl_state_bridge": "opl app state --profile fast --json",
    "opl_action_bridge": "opl app action execute --action <action_id> --dry-run --json",
    "native_bridge": "WKScriptMessageHandler window.webkit.messageHandlers.oplNativeWorkbench",
    "default_sandbox": "read-only",
    "conversation_persistence": "codex_app_server_thread_id_resume_capable",
    "settings_persistence": "localStorage model with SETTINGS_STORAGE_KEY, settingsDefaults, readSettings, writeSettings, readRuntimeProfile, and no system write permission",
    "execute_confirmation": "dry_run_first_then_explicit_confirm_before_execute",
    "typed_runtime_readback_surface": "normalized readState/readFullDrilldown envelopes with runtime profile, app_state/drilldown payload, and command readback metadata",
    "typed_action_receipt_surface": "normalized action receipts with requested mode, command args, parsed stdout/stderr JSON, and receipt status",
    "typed_event_surface": "typed bridge events with process/tool/file/diff/receipt/user_input/permission classification across native bridge and web SSE",
    "artifact_preview_mvp": "rich refs-only preview adapters for markdown, math, mermaid, code, and pdf",
    "professional_starters_mvp": "research, grant, presentation, and book starter forms route to real App state action refs; preview routes are not domain execution",
    "acp_app_server_reuse_status": "implemented_with_codex_app_server_thread_turn_stream"
  },
  "functional_mvp_closeout": {
    "implemented": [
      "Codex app-server thread/turn source path with initialize, thread/start, turn/start, streaming delta, turn/completed, and thread/resume markers",
      "OPL App state context source path using fast state, full state, full drilldown, and secondary runtime context refs",
      "OPL App action preview path using dry-run action commands and visible preview receipt markers",
      "Bridge helper layer normalizes runtime profile readback, action receipt shape, and typed event envelopes close to App state/action contracts",
      "Settings as a first-class route with a localStorage persistence model for model/account access, locale, runtime connection, project, and candidate-about controls",
      "Execute confirmation, rich artifact previews, and professional starters are represented as candidate MVP source markers",
      "Source-level candidate validators for the implemented markers and false-ready boundary"
    ],
    "partial": [
      "Packaged GUI artifact exists as candidate evidence, but packaged visual acceptance and clean-VM behavior are not proven here",
      "WebUI parity is source/smoke evidence only until same-cohort live user-path evidence exists",
      "Settings persistence is localStorage-only candidate evidence and does not request system write permission",
      "Artifact preview, provenance, starter, confirmation, and export surfaces are refs-only candidate UI, not artifact or owner authority"
    ],
    "local_candidate_live_smoke": {
      "command": "npm run smoke:native-live",
      "artifact": "out/native-live-smoke.json",
      "screenshot": "out/native-live-smoke.png",
      "scope": "local packaged macOS .app launch smoke with process evidence",
      "boundaries": {
        "active_shell_adopted": false,
        "release_ready": false,
        "clean_vm_ready": false,
        "domain_ready": false,
        "runtime_authority_transfer": false,
        "domain_truth_owned": false
      }
    },
    "not_ready": [
      "active_shell_adopted",
      "release_ready",
      "production_ready",
      "domain_ready",
      "clean_vm_ready",
      "full_release_ready",
      "live_evidence",
      "owner_receipt",
      "runtime_authority_transfer",
      "domain_truth_owned"
    ]
  },
