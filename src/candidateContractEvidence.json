    "dynamic_tools_policy": "client-executed runtime-probed tools reuse the typed host gate; models cannot supply permission decisions, target write sets, confirmation fields, or coordination IDs",
    "settings_persistence": "localStorage model with SETTINGS_STORAGE_KEY, settingsDefaults, readSettings, writeSettings, readRuntimeProfile, and no system write permission",
    "execute_confirmation": "dry_run_first_then_explicit_confirm_before_execute",
    "typed_runtime_readback_surface": "normalized readState/readFullDrilldown envelopes with runtime profile, app_state/drilldown payload, and command readback metadata",
    "typed_action_receipt_surface": "normalized action receipts with requested mode, command args, parsed stdout/stderr JSON, and receipt status",
    "typed_event_surface": "typed bridge events with process/tool/file/diff/receipt/user_input/permission classification across native bridge and web SSE",
    "artifact_preview_mvp": "rich refs-only preview adapters for markdown, math, mermaid, code, and pdf",
    "professional_starters_mvp": "research, grant, presentation, and book starter forms route to real App state action refs; preview routes are not domain execution",
    "agent_package_lifecycle_display": "package lifecycle rows consume app_state.agent_packages directory/status_index first, fall back to modules.items as preview-only, and expose only App/root action refs",
    "acp_app_server_reuse_status": "implemented_with_codex_app_server_thread_turn_stream"
  },
