{
  "name": "opl-native-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OPL native workbench candidate shell for One Person Lab App.",
  "license": "Apache-2.0",
  "dependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.4",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-tabs": "^1.1.16",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "streamdown": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "typescript": "5.8.3"
  },
  "scripts": {
    "dev": "node scripts/dev-webui-server.mjs",
    "webui": "node scripts/dev-webui-server.mjs",
    "build": "node scripts/build-renderer.mjs",
    "build:webui": "node scripts/build-webui.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "node scripts/package-native-workbench.mjs",
    "smoke:native-live": "node scripts/smoke-native-app-live.mjs",
    "test:native-command-output": "node scripts/native-command-output-regression.mjs",
    "test:model-list-pagination": "node scripts/model-list-pagination-regression.mjs",
    "test:thread-list-pagination": "node scripts/thread-list-pagination-regression.mjs",
    "test:gateway-account-projection": "bun run scripts/gateway-account-projection-regression.ts",
    "test:webui-host": "node --test scripts/webui-host/thread-adapter.test.mjs scripts/webui-host/http-host.test.mjs scripts/webui-host/opl-passthrough.test.mjs",
    "test:threads": "npm run test:thread-list-pagination && npm run test:webui-host && node --test tests/renderer/thread-renderer-source.test.mjs",
    "validate:candidate": "node scripts/validate-native-workbench-candidate.mjs",
    "validate:state-model": "node scripts/validate-state-model.mjs",
    "validate:package": "node scripts/validate-packaged-runtime.mjs",
    "smoke:webui": "node scripts/smoke-webui.mjs",
    "smoke:visual": "node scripts/smoke-visual.mjs",
    "test": "npm run typecheck && npm run test:native-command-output && npm run test:model-list-pagination && npm run test:gateway-account-projection && npm run test:threads && npm run validate:candidate && npm run validate:state-model && npm run smoke:webui && npm run smoke:visual && npm run package && npm run validate:package"
  }
}
